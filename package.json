{
  "name": "document-editor",
  "license": "MIT",
  "version": "1.0.0",
  "description": "A production-ready rich text document editor",
  "keywords": [
    "document-editor",
    "editor",
    "rich-text",
    "wysiwyg"
  ],
  "engines": {
    "node": ">=16.9.1"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode app",
    "serve": "vite preview",
    "lint": "eslint .",
    "type:check": "tsc --noEmit"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^10.0.1",
    "@types/node": "16.18.96",
    "@types/prismjs": "^1.26.0",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "eslint": "7.32.0",
    "typescript": "4.9.5",
    "vite": "^2.4.2",
    "vite-plugin-css-injected-by-js": "^2.1.1"
  },
  "dependencies": {
    "prismjs": "^1.27.0"
  }
}
